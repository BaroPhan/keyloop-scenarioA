PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=scheduler
DB_PASSWORD=schedulerpass
DB_DATABASE=scheduler

# Auto-create schema from entities (dev only). Use migrations in production.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (cache + BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=1h

# SMTP (Mailpit locally: host=localhost port=1025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
MAIL_FROM="Keyloop Scheduler <no-reply@keyloop.example>"
